# Frontend dev environment (used by `npm run dev`).
# Points at the LOCAL backend running on port 8000.

# API Configuration - local backend
VITE_API_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

# Hotel code sent as the X-Hotel-Code header (local backend is single-tenant, but harmless)
VITE_HOTEL_CODE=glimmora

# Environment
VITE_ENV=development

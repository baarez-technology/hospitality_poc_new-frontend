# Frontend Environment Variables for Production
# Backend runs on a DigitalOcean Droplet (168.144.30.61), behind nginx + Let's Encrypt TLS.

# API Configuration - Production backend URL (HTTPS, browser-trusted)
VITE_API_URL=https://jparkmain.duckdns.org
VITE_API_TIMEOUT=30000

# Hotel Code - default hotel for single-tenant deployments
VITE_HOTEL_CODE=glimmora

# Environment
VITE_ENV=production
